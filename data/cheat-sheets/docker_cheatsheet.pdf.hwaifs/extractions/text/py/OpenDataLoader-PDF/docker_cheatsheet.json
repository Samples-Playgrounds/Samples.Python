    "page number" : 1,
    "bounding box" : [ 36.0, 143.24, 296.988, 177.24 ],
    "font" : "TTCommons-Regular",
    "font size" : 10.0,
    "text color" : "[0.2062714546918869, 0.3035324513912201, 0.4133363962173462]",
    "content" : "Docker Hub is a service provided by Docker for finding and sharing container images with your team. Learn more and find images at https://hub.docker.com"
  }, {
    "type" : "image",
    "id" : 11,
    "page number" : 1,
    "bounding box" : [ 36.0, 33.957, 297.0, 135.54 ]
  }, {
