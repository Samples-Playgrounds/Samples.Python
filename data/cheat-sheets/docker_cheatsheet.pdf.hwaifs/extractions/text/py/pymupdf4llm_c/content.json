[{"page":1,"data":[{"type":"heading","bbox":[34.88,83.27,265.35,105.67],"length":15,"spans":[{"text":"CLI Cheat Sheet","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":35,"level":1},{"type":"text","bbox":[36.00,164.79,573.66,230.33],"length":501,"spans":[{"text":"Docker provides the ability to package and run an application in a loosely isolated environment called a container.\nThe isolation and security allows you to run many containers simultaneously on a given host. Containers are\nlightweight and contain everything needed to run the application, so you do not need to rely on what is currently\ninstalled on the host. You can easily share containers while you work, and be sure that everyone you share with gets\nthe same container that works in the same way.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":12,"lines":5},{"type":"heading","bbox":[36.00,273.10,120.56,282.06],"length":12,"spans":[{"text":"INSTALLATION","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"heading","bbox":[36.00,292.64,271.08,311.67],"length":86,"spans":[{"text":"Docker Desktop is available for Mac, Linux and Windows","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"https://docs.docker.com/desktop","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"level":4},{"type":"heading","bbox":[36.00,320.57,216.89,339.55],"length":79,"spans":[{"text":"View example projects that use Docker","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"https://github.com/docker/awesome-compose","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"level":4},{"type":"heading","bbox":[36.00,348.40,253.22,367.43],"length":74,"spans":[{"text":"Check out our docs for information on using Docker","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"https://docs.docker.com","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"level":4},{"type":"heading","bbox":[36.00,388.59,82.41,397.55],"length":6,"spans":[{"text":"IMAGES","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"text","bbox":[36.00,407.68,296.59,439.68],"length":190,"spans":[{"text":"Docker images are a lightweight, standalone, executable package of software that includes everything needed to run an application:\ncode, runtime, system tools, system libraries and settings.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"lines":3},{"type":"heading","bbox":[40.50,452.80,148.18,461.72],"length":32,"spans":[{"text":"Build an Image from a Dockerfile","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[41.00,464.30,167.00,470.65],"length":30,"spans":[{"text":"docker build -t \u003cimage_name\u003e .","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,478.00,210.94,486.92],"length":50,"spans":[{"text":"Build an Image from a Dockerfile without the cache","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,490.19,219.71,496.54],"length":40,"spans":[{"text":"docker build -t \u003cimage_name\u003e . –no-cache","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,505.00,95.86,511.40],"length":17,"spans":[{"text":"List local images","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,515.39,101.57,521.45],"length":13,"spans":[{"text":"docker images","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,530.20,94.63,536.60],"length":15,"spans":[{"text":"Delete an Image","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,540.59,146.33,546.94],"length":23,"spans":[{"text":"docker rmi \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,555.40,128.77,561.80],"length":24,"spans":[{"text":"Remove all unused images","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,565.79,123.47,571.85],"length":18,"spans":[{"text":"docker image prune","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[36.00,596.37,114.61,605.33],"length":10,"spans":[{"text":"DOCKER HUB","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"heading","bbox":[36.00,613.26,299.14,647.56],"length":152,"spans":[{"text":"Docker Hub is a service provided by Docker for finding and sharing container images with your team. Learn more and find images\nat https://hub.docker.com","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"level":4},{"type":"heading","bbox":[40.50,662.38,99.13,668.78],"length":17,"spans":[{"text":"Login into Docker","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,672.77,153.92,678.84],"length":26,"spans":[{"text":"docker login -u \u003cusername\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,687.58,146.79,693.98],"length":30,"spans":[{"text":"Publish an image to Docker Hub","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,697.78,193.23,704.32],"length":35,"spans":[{"text":"docker push \u003cusername\u003e/\u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,712.74,122.32,719.18],"length":23,"spans":[{"text":"Search Hub for an image","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,723.17,154.73,729.52],"length":26,"spans":[{"text":"docker search \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[40.50,737.94,148.64,744.38],"length":31,"spans":[{"text":"Pull an image from a Docker Hub","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[40.50,748.37,145.94,754.72],"length":24,"spans":[{"text":"docker pull \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[315.00,272.40,447.02,281.36],"length":16,"spans":[{"text":"GENERAL COMMANDS","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"heading","bbox":[319.50,297.18,402.50,302.30],"length":23,"spans":[{"text":"Start the docker daemon","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[319.50,307.83,358.77,312.39],"length":9,"spans":[{"text":"docker -d","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[319.50,322.38,526.03,328.74],"length":59,"spans":[{"text":"Get help with Docker. Can also use –help on all subcommands","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[319.50,333.03,375.68,338.87],"length":13,"spans":[{"text":"docker --help","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[319.50,347.58,428.18,353.98],"length":31,"spans":[{"text":"Display system-wide information","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[319.50,358.00,367.16,362.79],"length":11,"spans":[{"text":"docker info","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[315.00,388.84,392.00,397.80],"length":10,"spans":[{"text":"CONTAINERS","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"text","bbox":[315.00,407.88,566.30,463.93],"length":274,"spans":[{"text":"A container is a runtime instance of a docker image. A container\nwill always run the same, regardless of the infrastructure. Containers isolate software from its environment and ensure that it works uniformly despite differences for instance between\ndevelopment and staging.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":10,"lines":5},{"type":"text","bbox":[319.50,479.14,529.62,485.58],"length":61,"spans":[{"text":"Create and run a container from an image, with a custom name:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,489.56,526.31,495.92],"length":47,"spans":[{"text":"docker run --name \u003ccontainer_name\u003e \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,504.91,537.11,511.63],"length":67,"spans":[{"text":"Run a container with and publish a container’s port(s) to the host.","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,515.41,560.62,521.77],"length":55,"spans":[{"text":"docker run -p \u003chost_port\u003e:\u003ccontainer_port\u003e \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[319.50,530.88,434.82,537.28],"length":33,"spans":[{"text":"Run a container in the background","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[319.50,541.26,434.10,547.61],"length":26,"spans":[{"text":"docker run -d \u003cimage_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,556.68,434.67,563.12],"length":36,"spans":[{"text":"Start or stop an existing container:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,566.40,551.39,573.53],"length":54,"spans":[{"text":"docker start|stop \u003ccontainer_name\u003e (or \u003ccontainer-id\u003e)","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,582.57,416.83,588.89],"length":27,"spans":[{"text":"Remove a stopped container:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,592.96,433.44,599.31],"length":26,"spans":[{"text":"docker rm \u003ccontainer_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,608.38,451.79,614.82],"length":40,"spans":[{"text":"Open a shell inside a running container:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,618.80,471.35,625.16],"length":35,"spans":[{"text":"docker exec -it \u003ccontainer_name\u003e sh","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,634.23,452.99,640.67],"length":41,"spans":[{"text":"Fetch and follow the logs of a container:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,644.65,454.40,651.01],"length":31,"spans":[{"text":"docker logs -f \u003ccontainer_name\u003e","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,660.12,423.10,666.52],"length":31,"spans":[{"text":"To inspect a running container:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,670.50,540.58,676.85],"length":51,"spans":[{"text":"docker inspect \u003ccontainer_name\u003e (or \u003ccontainer_id\u003e)","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,685.96,438.20,692.36],"length":37,"spans":[{"text":"To list currently running containers:","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,696.58,358.67,702.42],"length":9,"spans":[{"text":"docker ps","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[319.50,711.69,481.03,718.41],"length":49,"spans":[{"text":"List all docker containers (running and stopped):","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":1},{"type":"text","bbox":[319.50,722.43,384.62,728.26],"length":15,"spans":[{"text":"docker ps --all","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"heading","bbox":[319.50,737.66,406.79,744.06],"length":25,"spans":[{"text":"View resource usage stats","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":8,"level":4},{"type":"text","bbox":[319.50,748.04,414.95,752.83],"length":22,"spans":[{"text":"docker container stats","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1}]}]
