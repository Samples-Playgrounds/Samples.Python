    "number of list items" : 3,
    "list items" : [ {
      "type" : "list item",
      "page number" : 5,
      "bounding box" : [ 90.0, 265.42, 518.372, 307.907 ],
      "font" : "ArialMT",
      "font size" : 10.995,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● number​ optionally indicates that several contiguous elements, beginning at ​address​, should be examined. This is very useful for examining the contents of an array. By default, this argument is 1.",
      "kids" : [ ]
    }, {
      "type" : "list item",
      "page number" : 5,
      "bounding box" : [ 90.0, 220.42, 531.023, 262.907 ],
      "font" : "ArialMT",
      "font size" : 10.995,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● format​ indicates how data should be printed. In most cases, this is the same character that you would use in a call to ​printf()​. One exception is the format i, which prints an instruction rather than a decimal integer.",
      "kids" : [ ]
    }, {
      "type" : "list item",
      "page number" : 5,
      "bounding box" : [ 90.0, 175.42, 527.814, 217.907 ],
      "font" : "ArialMT",
      "font size" : 10.995,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● unit_size​ indicates the size of the data to examine. It can be ​[b]ytes​, ​[h]alfwords (2 bytes), ​[w]ords​, or ​[g]iant​ ​words. By default, this is bytes, which is perfect for examining instructions.",
      "kids" : [ ]
    } ]
  }, {
    "type" : "paragraph",
    "id" : 102,
    "page number" : 5,
    "bounding box" : [ 72.0, 123.817, 489.42, 157.907 ],
    "font" : "ArialMT",
    "font size" : 10.995,
    "text color" : "[0.0, 0.0, 0.0]",
    "content" : "A variation of this command is the ​display​ command. This command takes the same arguments, but repeats execution every time ​gdb​ waits for input. For example,"
