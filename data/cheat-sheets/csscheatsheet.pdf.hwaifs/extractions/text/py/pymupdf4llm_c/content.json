":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":2},{"type":"text","bbox":[36.00,347.00,194.55,354.71],"length":47,"spans":[{"text":"P { font: italic bold 12pt/14pt Times, serif; }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.980003,"lines":1},{"type":"heading","bbox":[36.00,377.04,235.08,388.64],"length":31,"spans":[{"text":"Color and Background Properties","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":12,"level":3},{"type":"text","bbox":[35.96,390.78,138.81,410.34],"length":32,"spans":[{"text":"Color\nChanges the color of text.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":2},{"type":"text","bbox":[36.00,412.26,198.19,419.85],"length":45,"spans":[{"text":"H1 { color: blue; } or H2 { color: #000080; }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.9800024,"lines":1},{"type":"text","bbox":[36.00,431.82,200.23,451.38],"length":57,"spans":[{"text":"Background-Color\nSets the background color of an element.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":2},{"type":"text","bbox":[36.00,453.30,165.02,470.67],"length":67,"spans":[{"text":"BODY { background-color: white; }\nH1 { background-color: #000080; }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.980004,"lines":2},{"type":"text","bbox":[36.00,482.52,205.10,502.08],"length":57,"spans":[{"text":"Background-Image\nSets the background image of an element.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":2},{"type":"text","bbox":[36.00,503.96,265.94,521.37],"length":109,"spans":[{"text":"BODY { background-image: url(/images/foo.gif); }\nP { background-image: url(http://www.htmlhelp.com/bg.png); }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.979995,"lines":2},{"type":"text","bbox":[36.00,533.22,284.44,574.50],"length":187,"spans":[{"text":"Background-Repeat\nDetermines how a specified background image is repeated.\nThe repeat-x value will repeat the image horizontally while the\nrepeat-y value will repeat the image vertically.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":4},{"type":"text","bbox":[36.00,576.38,197.54,593.79],"length":74,"spans":[{"text":"BODY { background: white url(candybar.gif);\nbackground-repeat: repeat-x; }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.9800014,"lines":2},{"type":"text","bbox":[36.00,605.64,284.10,636.06],"length":132,"spans":[{"text":"Background-Attachment\nDetermines if a specified background image will scroll with the\ncontent or be fixed with regard to the canvas.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":3},{"type":"text","bbox":[36.00,637.94,197.54,655.35],"length":75,"spans":[{"text":"BODY { background: white url(candybar.gif);\nbackground-attachment: fixed; }","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7.9800014,"lines":2},{"type":"t