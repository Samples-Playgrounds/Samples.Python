[{"0":"Command\nDescription\nExamples and Options","1":"","2":""},{"0":"<tab>\nAttempt to autocomplete\nUse this to speed up typing\/avoid typos","1":"","2":""},{"0":"Navigating Directories","1":"","2":""},{"0":"ls","1":"List the contents of the directory.","2":"ls -larth\n\/home\/mcuser\/science\/code"},{"0":"cd","1":"Change directory.","2":"cd \/home\/mcuser\/science"},{"0":"pwd","1":"present w orking d irectory.","2":"pwd"},{"0":"*","1":"Wild card, any number of chars.","2":"ls *.txt"},{"0":"?","1":"Wild card, 0 or 1 characters.","2":"ls foo?.txt"},{"0":".","1":"Current directory.","2":"cd ."},{"0":"..","1":"Directory one level up.","2":"cd .."},{"0":"~","1":"Home directory.","2":"cd ~"},{"0":"-","1":"Previous directory.","2":"cd -"},{"0":"Modifying Directories and Files","1":"","2":""},{"0":"mkdir","1":"Make new empty directory.","2":"mkdir MyNewDirectory"},{"0":"rmdir","1":"Remove empty directory.","2":"rmdir MyNewDirectory"},{"0":"mv","1":"Move \ufb01les (overwrites destination).","2":"mv -i\nfoo.txt foo2.txt"},{"0":"cp","1":"Copy \ufb01les (overwrites destination).","2":"cp -i\n..\/foo.txt\n."},{"0":"rm","1":"Remove \ufb01les. CANNOT UNDO!","2":"rm -i\nfoo.txt"},{"0":"chmod","1":"Change \ufb01le permissions.\nrwx = read, write, execute.\nugoa = user, group, other, all.","2":"chmod a+rwx\nbadger.txt\nchmod o-wx\nbadger.txt\nchmod u+x\nmyscript.sh"},{"0":"Viewing Files in Terminal","1":"","2":""},{"0":"less","1":"View \ufb01les in terminal window.","2":"less foo.txt"},{"0":"cat","1":"Concatenate \ufb01les.","2":"cat foo1.txt foo2.txt"},{"0":"head","1":"Display \ufb01rst 10 lines.","2":"head -20\nfoo.txt"},{"0":"tail","1":"Display last 10 lines.","2":"tail -f\nlogfile.txt"},{"0":"Searching","1":"","2":""},{"0":"grep","1":"Search for word(s) in a \ufb01le.","2":"grep myvarname *.txt\ngrep rodent\n*.txt\ngrep \"Hello\nWorld\"\n*.txt"},{"0":"find","1":"Search\na\npath\nfor\n\ufb01les\/directories\nthat match some speci\ufb01cation.","2":"find playground -name\n\"*.txt\"\nfind playground -type\nd\nfind playground -not\n-name\n\"*.txt\""},{"0":"Environment Variables","1":"","2":""},{"0":"$HOME","1":"Home directory.","2":"workpath=$HOME\/playground"},{"0":"$SHELL","1":"Shell name.","2":"echo $SHELL"},{"0":"$USER","1":"User name.","2":"echo $USER"},{"0":"$PATH","1":"Paths to look in for executables.","2":"PATH=${PATH}:\/my\/new\/program\/path\/bin"},{"0":"env","1":"List environment vars and values.","2":"env |\nless"}]