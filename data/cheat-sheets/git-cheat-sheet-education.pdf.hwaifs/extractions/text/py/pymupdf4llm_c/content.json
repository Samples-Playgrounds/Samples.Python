[{"page":1,"data":[{"type":"heading","bbox":[38.92,73.51,223.21,91.99],"length":15,"spans":[{"text":"GIT CHEAT SHEET","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":24,"level":1},{"type":"text","bbox":[35.43,159.88,578.01,206.00],"length":250,"spans":[{"text":"Git is the free and open source distributed version control system that's responsible for everything GitHub\nrelated that happens locally on your computer. This cheat sheet features the most important and commonly\nused Git commands for easy reference.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":12,"lines":3},{"type":"heading","bbox":[36.00,258.50,144.39,267.21],"length":19,"spans":[{"text":"INSTALLATION \u0026 GUIS","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":11,"level":4},{"type":"text","bbox":[36.00,271.00,286.81,314.60],"length":255,"spans":[{"text":"With platform specific installers for Git, GitHub also provides the ease of staying up-to-date with the latest releases of the command line tool while providing a graphical user interface for day-to-day interaction, review, and repository synchronization.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":4},{"type":"text","bbox":[36.00,327.08,140.81,347.18],"length":45,"spans":[{"text":"GitHub for Windows","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"https://windows.github.com","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":9,"lines":2},{"type":"text","bbox":[36.00,359.48,123.48,379.5