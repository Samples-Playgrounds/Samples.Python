lse,"superscript":false,"subscript":false,"link":false}],"font_size":8,"lines":2}]},{"page":2,"data":[{"type":"heading","bbox":[65.19,72.60,192.25,86.14],"length":18,"spans":[{"text":"06 Inspect history","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"heading","bbox":[438.44,72.60,645.61,86.30],"length":29,"spans":[{"text":"09 Synchronizing repositories","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"table","bbox":[56.69,89.74,785.20,241.50],"length":0,"font_size":0,"row_count":3,"col_count":4,"cell_count":12,"rows":[{"bbox":[56.69,89.74,785.20,120.54],"cells":[{"bbox":[65.19,103.12,141.10,110.19],"spans":[{"text":"git log [-n count]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,98.93,402.19,113.34],"spans":[{"text":"List commit history of current branch. -n count limits list to last n commits.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.44,103.25,515.22,110.32],"spans":[{"text":"git fetch [remote]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[559.94,99.05,752.17,113.47],"spans":[{"text":"Fetch changes from the remote, but not update tracking branches.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]},{"bbox":[56.69,120.54,785.20,211.26],"cells":[{"bbox":[65.19,129.24,143.13,200.93],"spans":[{"text":"git log --oneline --graph --decorate git log ref.. git log ..ref","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,129.17,402.50,204.09],"spans":[{"text":"An overview with reference labels and history graph. One commit per line. List commits that are present on the current branch and not merged into ref. A ref can be a branch name or a tag name. List commit that are present on ref and not merged into current branch.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.44,129.36,511.64,205.07],"spans":[{"text":"git fetch --prune [remote] git pull [remote] git push [--tags] [remote]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[559.94,129.30,775.55,201.13],"spans":[{"text":"Delete remote Refs that were removed from the remote repository. Fetch changes from the remote and merge current branch with its upstream. Push local changes to the remote. Use --tags to push tags.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]},{"bbox":[56.69,211.26,785.20,241.50],"cells":[{"bbox":[65.19,224.48,108.70,231.18],"spans":[{"text":"git reflog","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,219.91,383.56,235.68],"spans":[{"text":"List operations (e.g. checkouts or commits) made on local repository.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.45,219.73,523.38,235.32],"spans":[{"text":"git push -u [remote] [branch]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[559.94,220.12,757.18,235.80],"spans":[{"text":"Push local branch to remote repository. Set its copy as an upstream.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]}]},{"type":"heading","bbox":[65.19,263.22,205.83,276.92],"length":18,"spans":[{"text":"07 Tagging commits","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"text","bbox":[65.19,290.24,227.45,297.01],"length":22,"spans":[{"text":"git tag","font_size":0,"bold":false,"italic":false,"monospace":true,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"List all tags.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":2},{"type":"heading","bbox":[438.44,263.15,559.01,274.03],"length":19,"spans":[{"text":"10 Git installation","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"text","bbox":[438.44,289.48,748.27,305.24],"length":145,"spans":[{"text":"For GNU/Linux distributions, Git should be available in the standard system repository. For\nexample, in Debian/Ubuntu please type inthe terminal:","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":2},{"type":"table","bbox":[56.69,303.36,785.20,520.48],"length":0,"font_size":0,"row_count":5,"col_count":3,"cell_count":15,"rows":[{"bbox":[56.69,303.36,785.20,363.84],"cells":[{"bbox":[65.19,311.74,137.03,357.57],"spans":[{"text":"git tag [name] [commit sha] git tag -a [name] [commit sha]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,312.05,393.30,353.63],"spans":[{"text":"Create a tag reference named name for current commit. Add commit sha to tag a specific commit instead of current one. Create a tag object named name for current commit.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.44,318.18,515.62,324.94],"spans":[{"text":"sudo apt-get install git","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]},{"bbox":[56.69,363.84,411.95,390.84],"cells":[{"bbox":[65.19,375.11,137.10,382.18],"spans":[{"text":"git tag -d [name]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,375.41,307.40,382.25],"spans":[{"text":"Remove a tag from local repository.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[429.95,404.81,785.20,423.38],"cells":[{"bbox":[438.44,412.51,545.38,419.21],"spans":[{"text":"cat \u003c \u003cEOF \u003e .gitignore","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[56.69,423.38,785.20,495.38],"cells":[{"bbox":[65.19,453.61,142.83,469.68],"spans":[{"text":"git reset [--hard] [target reference]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,444.91,399.46,478.76],"spans":[{"text":"Switches the current branch to the target reference, leaving a difference as an uncommitted change. When --hard is used,all changes are discarded. It's easy to lose uncommitted changes with --hard.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.44,430.14,497.17,491.20],"spans":[{"text":"/logs / * !logs/.gitkeep /tmp *.swp","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]},{"bbox":[56.69,490.24,785.20,520.48],"cells":[{"bbox":[65.19,503.13,163.51,510.20],"spans":[{"text":"git revert [commit sha]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.68,498.93,389.06,514.78],"spans":[{"text":"Create a new commit, reverting changes from the specified commit. It generates an inversion of changes.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[438.44,502.76,451.42,508.01],"spans":[{"text":"EOF","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]}]},{"type":"text","bbox":[438.44,523.82,768.42,548.66],"length":316,"spans":[{"text":"To ignore files, create a .gitignore file in your repository with a line for each pattern. File ignoring will\nwork for the current and sub directories where .gitignore file is placed. In this example, all files are\nignored in the logs directory (excluding the .gitkeep file), whole tmp directory and all files *.swp.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":3}]}]
