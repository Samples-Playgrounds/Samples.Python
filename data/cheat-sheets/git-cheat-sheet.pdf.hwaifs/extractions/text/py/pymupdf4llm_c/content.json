ont_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":".","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":1},{"type":"text","bbox":[65.19,526.93,389.98,541.36],"length":97,"spans":[{"text":"git reset [\u003cpath\u003e...]","font_size":0,"bold":false,"italic":false,"monospace":true,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"Revert some paths in the index (or the whole index) to their\nstate in","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"HEAD.","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":3},{"type":"text","bbox":[65.19,552.28,406.25,568.17],"length":102,"spans":[{"text":"git commit","font_size":0,"bold":false,"italic":false,"monospace":true,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"Create a new commit from changes added to the","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"staging area.","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"The","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"commit","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"must have a message!","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":7,"lines":3},{"type":"text","bbox":[511.57,495.88,652.