[{"page":1,"data":[{"type":"heading","bbox":[56.69,25.80,223.79,42.82],"length":15,"spans":[{"text":"Git Cheat Sheet","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":22,"level":1},{"type":"heading","bbox":[65.19,95.98,202.14,109.68],"length":20,"spans":[{"text":"01 Git configuration","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}],"font_size":14,"level":2},{"type":"table","bbox":[56.69,113.19,785.20,455.78],"length":0,"font_size":0,"row_count":9,"col_count":3,"cell_count":27,"rows":[{"bbox":[56.69,113.19,785.20,140.63],"cells":[{"bbox":[65.19,120.76,155.51,135.27],"spans":[{"text":"git config --global user.name “Your Name”","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,125.27,393.85,132.03],"spans":[{"text":"Set the name that will be attached to your commits and tags.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[559.94,122.63,746.07,129.53],"spans":[{"text":"Remove file from working directory and staging area.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]}]},{"bbox":[551.32,177.75,785.20,205.89],"cells":[{"bbox":[559.94,184.56,767.24,199.03],"spans":[{"text":"Put current changes in your working directory into stash for later use.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[551.32,205.89,785.20,231.55],"cells":[{"bbox":[559.94,211.57,768.76,226.04],"spans":[{"text":"Apply stored stash content into working directory, and clear stash.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[551.32,231.55,785.20,254.05],"cells":[{"bbox":[559.94,240.87,746.52,247.63],"spans":[{"text":"Delete a specific stash from all your previous stashes.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[56.69,246.86,411.95,297.76],"cells":[{"bbox":[65.19,270.32,163.55,277.39],"spans":[{"text":"git init [project name]","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,261.62,389.05,286.39],"spans":[{"text":"Create a new local repository in the current directory. If [project name] is provided, Git will create a new directory named [project name] and will initialize a repository inside it.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[551.32,293.29,785.20,322.84],"cells":[{"bbox":[559.94,301.06,772.87,316.34],"spans":[{"text":"List all local branches in repository. With -a: show all branches (with remote).","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[551.32,322.84,785.20,428.78],"cells":[{"bbox":[559.94,329.52,774.63,424.62],"spans":[{"text":"Create new branch, referencing the current HEAD. Apply commits of the current working branch and apply them to the HEAD of [branch] to make the history of your branch more linear. Switch working directory to the specified branch. With -b: Git will create the specified branch if it does not exist. Join specified [branch _ name] branch into your current branch (the one you are on currently).","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[56.69,363.65,411.95,403.75],"cells":[{"bbox":[65.19,382.08,108.38,388.78],"spans":[{"text":"git status","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[186.69,373.01,396.59,397.86],"spans":[{"text":"Displays the status of your working directory. Options include new, staged, and modified files. It will retrieve branch name, current commit identifier, and changes pending commit.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]}]},{"bbox":[551.32,428.78,785.20,455.78],"cells":[{"bbox":[559.94,435.86,772.67,450.28],"spans":[{"text":"Remove selected branch, if it is already merged into any other. -D instead of -d forces deletion.","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false}]},{"bbox":[0.00,0.00,0.00,0.00]},{"bbox":[0.00,0.00,0.00,0.00]}]}]},{"type":"text","bbox":[65.19,452.37,396.91,459.51],"length":72,"spans":[{"text":"git diff [file]","font_size":0,"bold":false,"italic":false,"monospace":true,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"Show changes between","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"working directory","font_size":0,"bold":true,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":false},{"text":"and","font_size":0,"bold":false,"italic":false,"monospace":false,"strikeout":false,"superscript":false,"subscript":false,"link":fa