ta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1591, 1592], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1591, 1592], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="That G_M000_IG02 section is doing the null check and the length check, jumping to the G_M000_IG05 block if either fails. If both succeed, it's then executing the loop (block G_M000_IG03) without bounds checks:", markup='', info='', meta={}, block=False, hidden=False)], content="That G\\_M000\\_IG02 section is doing the null check and the length check, jumping to the G\\_M000\\_IG05 block if either fails. If both succeed, it's then executing the loop (block G\\_M000\\_IG03) without bounds checks:", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1593, 1600], level=0, children=None, content='G_M000_IG03: ;; offset=0020H\n 8BD0 mov edx, eax\n 837C91102A cmp dword ptr [rcx+4*rdx+10H], 42\n 7429 je SHORT G_M000_IG08\n FFC0 inc eax\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1601, 1605], level=0, children=None, content=' 3D45230100 cmp eax, 0x12345\n 7CEE jl SHORT G_M000_IG03\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1606, 1607], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1606, 1607], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='with the bounds chec