ter than the StreamWriter that was previously employed. In doing so, the implementation avoids the overheads (primarily in allocation) of the streams and writers and temporary buffers.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6315, 6324], level=0, children=None, content='private string _path;\n[GlobalSetup]\npublic void Setup() => _path = Path.GetRandomFileName();\n[GlobalCleanup]\npublic void Cleanup() => File.Delete(_path);\n[Benchmark]\npublic void WriteAllText() => File.WriteAllText(_path, Sonnet);\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='table_open', tag='table', nesting=1, attrs={}, map=[6325, 6329], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='thead_open', tag='thead', nesting=1, attrs={}, map=[6325, 6326], level=1, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='tr_open', tag='tr', nesting=1, attrs={}, map=[6325, 6326], level=2, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6325, 6326], level=4, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Method', markup='', info='', meta={}, block=False, hidden=False)], content='Method', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_close', tag='th', nesting=-1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=No