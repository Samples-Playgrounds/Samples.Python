\n builder.Write(tmp.Slice(0, charsWritten));\n}\nref struct SpanWriter\n{\n private readonly Span<char> _chars;\n private int _length;\n public SpanWriter(Span<char> destination) => _chars = destination;\n public Span<char> AsSpan() => _chars.Slice(0, _length);\n public void Write(ReadOnlySpan<char> value)\n {\n if (_length > _chars.Length - value.Length)\n {\n throw new InvalidOperationException("Not enough remaining space");\n }\n value.CopyTo(_chars.Slice(_length));\n _length += value.Length;\n }\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[5141, 5142], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[5141, 5142], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='We have a ref struct SpanWriter that takes a Span', markup='', info='', meta={}, block=False, hidden=False), Token(type='html_inline', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='<char>', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' to its constructor and allows for writing to it by copying in additional content and then updating the stored length. The Write method accepts a ReadOnlySpan', markup='', info='', meta={}, block=False, hidden=False), Token(type='html_inline', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='<char>', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=". And we then have a helper Append method which is formatting a byte into some stackalloc'd temporary space and passing the resulting formatted chars in to Write. Straightforward. Except, this doesn't compile:", markup='', info='', meta={}, block=False, hidden=False)], content="We have a ref struct SpanWriter that takes a Span<char> to its constructor and allows for writing to it by copying in additional content and then updating the stored length. The Write method accepts a ReadOnlySpan<char>. And we then have a helper Append method which is formatting a byte into some stackalloc'd temporary space and passing the resulting formatted chars in to Write. Straightforward. Except, this doesn't compile:", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[5143, 5144], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[5143, 5144], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="error CS8350: This combination of arguments to 'SpanWriter.Write(ReadOnlySpan", markup='', info='', meta={}, block=False, hidden=False), Token(type='html_inline', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='<char>', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=")' is disallowed because it may expose variables referenced by parameter 'value' outside of their declaration scope", markup='', info='', meta={}, block=False, hidden=False)], content="error CS8350: This combination of arguments to 'SpanWriter.Write(ReadOnlySpan<char>)' is disallowed because it may expose variables referenced by parameter 'value' outside of their declaration scope", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}