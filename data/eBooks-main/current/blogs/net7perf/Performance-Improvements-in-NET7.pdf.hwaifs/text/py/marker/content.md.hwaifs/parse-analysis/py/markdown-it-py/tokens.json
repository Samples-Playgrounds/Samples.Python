e_close', tag='table', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6240, 6241], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6240, 6241], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='The rest of the performance-focused changes around I/O in .NET 7 were primarily focused on one of two things: reducing syscalls, and reducing allocation.', markup='', info='', meta={}, block=False, hidden=False)], content='The rest of the performance-focused changes around I/O in .NET 7 were primarily focused on one of two things: reducing syscalls, and reducing allocation.', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6242, 6243], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6242, 6243], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Several PRs went into reducing syscalls on Unix as part of copying files, e.g. File.Copy and FileInfo.CopyTo. ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/59695'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#59695', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/tmds'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@tmds', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' reduced overheads in several ways. The code had been performing a stat call in order to determine up front whether the source was actually a directory, in which case the operation would error out. Instead, the PR simply tries to open the source file, which it would need to do anyway for the copy operation, and then it only performs that stat if opening the file fails. If opening the file succeeds, the code was already performing an fstat to gather data on the file, such as whether it was seekable; with this change, it now also extracts from the results of that single fstat the source file size, which it then threads through to the core copy routine, which itself is then able to avoid an fstat syscall it had been performing in order to get the size. Saving those syscalls is great, in particular for very small files where the overhead of setting up the copy can actually be more expensive than the actual copy of the bytes. But the biggest benefit of this PR is that it takes advantage of IOCTL-FICLONERANGE on Linux. Some Linux file systems, like XFS and Btrfs, support "copy-on-write," which means that rather than copying all of the data to a new file, the file system simply notes that there are two different files pointing to the same data, sharing the underlying storage. This makes the "copy" super fast, since nothing actually needs to be copied and instead the file system just needs to update some bookkeeping; plus, less space is consumed on disk, since there\'s just a single store of the data. The file system then only needs to actually copy data that\'s overwritten in one of the files. This PR uses ioctl and FICLONE to perform the copy as copy-on-write if the source and destination file system are the same and the file system supports the operation. In a similar vein, ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/64264'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#64264', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/tmds'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@tmds', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" further improves File.Copy/FileInfo.CopyTo by utilizing copy_file_range on Linux if it's supported (and only if it's a new enough kernel that it addresses", markup='', info='', meta={}, block=False, hidden=False)], content='Several PRs went into reducing syscalls on Unix as part of copying files, e.g. File.Copy and FileInfo.CopyTo. [dotnet/runtime#59695](https://github.com/dotnet/runtime/pull/59695) from [@tmds](https://github.com/tmds) reduced overheads in several ways. The code had been performing a stat call in order to determine up front whether the source was actually a directory, in which case the operation would error out. Instead, the PR simply tries to open the source file, which it would need to do anyway for the copy operation, and then it only performs that stat if opening the file fails. If opening the file succeeds, the code was already performing an fstat to gather data on the file, such as whether it was seekable; with this change, it now also extracts from the results of that single fstat the source file size, which it then threads through to the core copy routine, which itself is then able to avoid an fstat syscall it had been performing in order to get the size. Saving those syscalls is great, in particular for very small files where the overhead of setting up the copy can actually be more expensive than the actual copy of the bytes. But the biggest benefit of this PR is that it takes advantage of IOCTL-FICLONERANGE on Linux. Some Linux file systems, like XFS and Btrfs, support "copy-on-write," which means that rather than copying all of the data to a new file, the file system simply notes that there are two different files pointing to the same data, sharing the underlying storage. This makes the "copy" super fast, since nothing actually needs to be copied and instead the file system just needs to update some bookkeeping; plus, less space is consumed on disk, since there\'s just a single store of the data. The file system then only needs to actually copy data that\'s overwritten in one of the files. This PR uses ioctl and FICLONE to perform the copy as copy-on-write if the source and destination file system are the same and the file system supports the operation. In a similar vein, [dotnet/runtime#64264](https://github.com/dotnet/runtime/pull/64264) from [@tmds](https://github.com/tmds) further improves File.Copy/FileInfo.CopyTo by utilizing copy\\_file\\_range on Linux if it\'s supported (and only if it\'s a new enough kernel that it addresses', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6244, 6245], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6244, 6245], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='some issues the function had in previous releases). Unlike a typical read/write loop that reads the data from the source and then writes it to the destination, copy_file_range is implemented to stay entirely in kernel mode, without having to transition to user space for each read and write.', markup='', info='', meta={}, block=False, hidden=False)], content='some issues the function had in previous releases). Unlike a typical read/write loop that reads the data from the source and then writes it to the destination, copy\\_file\\_range is implemented to stay entirely in kernel mode, without having to transition to user space for each read and write.', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6246, 6247], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6246, 6247], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Another example of avoiding syscalls comes for the File.WriteXx and File.AppendXx methods when on Unix. The implementation of these methods opens a FileStream or a SafeFileHandle directly, and it was specifying FileOptions.SequentialScan. SequentialScan is primarily relevant for reading data from a file, and hints to OS caching to expect data to be read from the file sequentially rather than randomly. However, these write/append methods don\'t read, they only write, and the implementation of FileOptions.SequentialScan on Unix requires an additional syscall via posix_fadvise (passing in POSIX_FADV_SEQUENTIAL); thus, we\'re paying for a syscall and not benefiting from it. This situation is akin to the famous Henny Youngman joke: "The patient says, \'Doctor, it hurts when I do this\'; the doctor says, \'Then don\'t do that!\'." Here, too, the answer is "don\'t do that," and so ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/59247'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#59247', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/tmds'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@tmds', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" simply stops passing SequentialScan in places where it won't help but may hurt.", markup='', info='', meta={}, block=False, hidden=False)], content='Another example of avoiding syscalls comes for the File.WriteXx and File.AppendXx methods when on Unix. The implementation of these methods opens a FileStream or a SafeFileHandle directly, and it was specifying FileOptions.SequentialScan. SequentialScan is primarily relevant for reading data from a file, and hints to OS caching to expect data to be read from the file sequentially rather than randomly. However, these write/append methods don\'t read, they only write, and the implementation of FileOptions.SequentialScan on Unix requires an additional syscall via posix\\_fadvise (passing in POSIX\\_FADV\\_SEQUENTIAL); thus, we\'re paying for a syscall and not benefiting from it. This situation is akin to the famous Henny Youngman joke: "The patient says, \'Doctor, it hurts when I do this\'; the doctor says, \'Then don\'t do that!\'." Here, too, the answer is "don\'t do that," and so [dotnet/runtime#59247](https://github.com/dotnet/runtime/pull/59247) from [@tmds](https://github.com/tmds) simply stops passing SequentialScan in places where it won\'t help but may hurt.', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6248, 6249], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6248, 6249], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Directory handling has seen reduced syscalls across the directory lifecycle, especially on Unix. ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/58799'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#58799', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/tmds'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@tmds', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" speeds up directory creation on Unix. Previously, the implementation of directory creation would first check to see if the directory already existed, which involves a syscall. In the expected minority case where it already existed the code could early exit out. But in the expected more common case where the directory didn't exist, it would then parse the file path to find all of the directories in it, walk up the directory list until it found one that did exist, and then try to create all of the subdirectories back down through the target one. However, the expected most common case is the parent directories already exist and the child directory doesn't, in which case we're still paying for all that parsing when we could have just created the target directory. This PR addresses that by changing the up-front existence check to instead simply try to mkdir the target directory; if it succeeds, great, we're done, and if it fails, the error code from the failure can be used instead of the existence check to know whether mkdir failed because it had no work to do. ", markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/61777'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#61777', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' then takes this a step further and avoids string allocations while creating directories by using stack memory for the paths temporarily needed to pass to mkdir.', markup='', info='', meta={}, block=False, hidden=False)], content="Directory handling has seen reduced syscalls across the directory lifecycle, especially on Unix. [dotnet/runtime#58799](https://github.com/dotnet/runtime/pull/58799) from [@tmds](https://github.com/tmds) speeds up directory creation on Unix. Previously, the implementation of directory creation would first check to see if the directory already existed, which involves a syscall. In the expected minority case where it already existed the code could early exit out. But in the expected more common case where the directory didn't exist, it would then parse the file path to find all of the directories in it, walk up the directory list until it found one that did exist, and then try to create all of the subdirectories back down through the target one. However, the expected most common case is the parent directories already exist and the child directory doesn't, in which case we're still paying for all that parsing when we could have just created the target directory. This PR addresses that by changing the up-front existence check to instead simply try to mkdir the target directory; if it succeeds, great, we're done, and if it fails, the error code from the failure can be used instead of the existence check to know whether mkdir failed because it had no work to do. [dotnet/runtime#61777](https://github.com/dotnet/runtime/pull/61777) then takes this a step further and avoids string allocations while creating directories by using stack memory for the paths temporarily needed to pass to mkdir.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6250, 6251], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6250, 6251], level=1, children=[Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/63675'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#63675', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" then improves the performance of moving directories, on both Unix and Windows, removing several syscalls. The shared code for Directory.Move and DirectorInfo.MoveTo was doing explicit directory existence checks for the source and destination locations, but on Windows the Win32 API called to perform the move does such checks itself, so they're not needed preemptively. On Unix, we can similarly avoid the existence check for the source directory, as the rename function called will similarly simply fail if the source doesn't exist (with an appropriate error that let's us deduce what went wrong so the right exception can be thrown), and for the destination, the code had been issuing separate existence checks for whether the destination existed as a directory or as a file, but a single stat call suffices for both.", markup='', info='', meta={}, block=False, hidden=False)], content="[dotnet/runtime#63675](https://github.com/dotnet/runtime/pull/63675) then improves the performance of moving directories, on both Unix and Windows, removing several syscalls. The shared code for Directory.Move and DirectorInfo.MoveTo was doing explicit directory existence checks for the source and destination locations, but on Windows the Win32 API called to perform the move does such checks itself, so they're not needed preemptively. On Unix, we can similarly avoid the existence check for the source directory, as the rename function called will similarly simply fail if the source doesn't exist (with an appropriate error that let's us deduce what went wrong so the right exception can be thrown), and for the destination, the code had been issuing separate existence checks for whether the destination existed as a directory or as a file, but a single stat call suffices for both.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6252, 6261], level=0, children=None, content='private string _path1;\nprivate string _path2;\n[GlobalSetup]\npublic void Setup()\n{\n _path1 = Path.GetTempFileName();\n _path2 = Path.GetTempFileName();\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6262, 6274], level=0, children=None, content=' File.Delete(_path1);\n File.Delete(_path2);\n Directory.CreateDirectory(_path1);\n}\n[Benchmark]\npublic void Move()\n{\n Directory.Move(_path1, _path2);\n Directory.Move(_path2, _path1);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='table_open', tag='table', nesting=1, attrs={}, map=[6275, 6279], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='thead_open', tag='thead', nesting=1, attrs={}, map=[6275, 6276], level=1, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='tr_open', tag='tr', nesting=1, attrs={}, map=[6275, 6276], level=2, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6275, 6276], level=4, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Method', markup='', i