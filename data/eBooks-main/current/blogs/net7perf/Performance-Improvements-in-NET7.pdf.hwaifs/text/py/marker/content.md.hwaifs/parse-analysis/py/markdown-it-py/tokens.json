='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6692, 6693], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6692, 6693], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="One final change related to reading and writing performance on an SslStream. I find this one particularly interesting, as it highlights a new and powerful C# 11 and .NET 7 feature: static abstract members in interfaces. SslStream, as with every Stream, exposes both synchronous and asynchronous methods for reading and writing. And as you may be aware, the code within SslStream for implementing reads and writes is not particularly small. Thus, we really want to avoid having to duplicate all of the code paths, once for synchronous work and once for asynchronous work, when in reality the only place that bifurcation is needed is at the leaves where calls into the underlying Stream are made to perform the actual I/O. Historically, we've had two different mechanisms we've employed in ", markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' for handling such unification. One is to make all methods async, but with an additional bool useAsync parameter that gets fed through the call chain, then branching based on it at the leaves, e.g.', markup='', info='', meta={}, block=False, hidden=False)], content="One final change related to reading and writing performance on an SslStream. I find this one particularly interesting, as it highlights a new and powerful C# 11 and .NET 7 feature: static abstract members in interfaces. SslStream, as with every Stream, exposes both synchronous and asynchronous methods for reading and writing. And as you may be aware, the code within SslStream for implementing reads and writes is not particularly small. Thus, we really want to avoid having to duplicate all of the code paths, once for synchronous work and once for asynchronous work, when in reality the only place that bifurcation is needed is at the leaves where calls into the underlying Stream are made to perform the actual I/O. Historically, we've had two different mechanisms we've employed in [dotnet/runtime](https://github.com/dotnet/runtime) for handling such unification. One is to make all methods async, but with an additional bool useAsync parameter that gets fed through the call chain, then branching based on it at the leaves, e.g.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6694, 6715], level=0, children=None, content='public static void Work(Stream s) =>\n A(s, useAsyunc: false).GetAwaiter().GetResult(); // GetResult() to propagate any \nexceptions\npublic static Task WorkAsync(Stream S) =>\n A(s, useAsync: true);\ninternal static async Task A(Stream s, bool useAsync)\n{\n ...\n await B(s, useAsync);\n ...\n}\nprivate static async Task B(Stream s, bool useAsync)\n{\n ...\n int bytesRead = useAsync ?\n await s.ReadAsync(buffer) :\n s.Read(buffer.Span);\n ...\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6716, 6717], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6716, 6717], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="This way most of the logic and code is shared, and when useAsync is false, everything completes synchronously and so we don't pay for allocation that might otherwise be associated with the asyncness. The other approach is similar in spirit, but instead of a bool parameter, taking advantage of generic specialization and interface-implementing structs. Consider an interface like:", markup='', info='', meta={}, block=False, hidden=False)], content="This way most of the logic and code is shared, and when useAsync is false, everything completes synchronously and so we don't pay for allocation that might otherwise be associated with the asyncness. The other approach is similar in spirit, but instead of a bool parameter, taking advantage of generic specialization and interface-implementing structs. Consider an interface like:", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6718, 6724], level=0, children=None, content='interface IReader\n{\n ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6725, 6726], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6725, 6726], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='We can then declare two implementations of this interface:', markup='', info='', meta={}, block=False, hidden=False)], content='We can then declare two implementations of this interface:', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6727, 6739], level=0, children=None, content='struct SyncReader : IReader\n{\n public ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer) =>\n new ValueTask<int>(s.Read(buffer.Span));\n}\nstruct AsyncReader : IReader\n{\n public ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer) =>\n s.ReadAsync(buffer);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6740, 6741], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6740, 6741], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Then we can redeclare our earlier example as:', markup='', info='', meta={}, block=False, hidden=False)], content='Then we can redeclare our earlier example as:', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6742, 6760], level=0, children=None, content='public static void Work(Stream s) =>\n A(stream, default(SyncReader)).GetAwaiter().GetResult(); // to propagate any exceptions\npublic static Task WorkAsync(Stream S) =>\n A(s, default(AsyncReader));\ninternal static async Task A<TReader>(Stream s, TReader reader) where TReader : IReader\n{\n ...\n await B(s, reader);\n ...\n}\nprivate static async Task B<TReader>(Stream s, TReader reader) where TReader : IReader\n{\n ...\n int bytesRead = await reader.ReadAsync(s, buffer);\n ...\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6761, 6762], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6761, 6762], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Note that the generic constraint on the TReader parameter here allows the implementation to invoke the interface methods, and passing the structs as a generic avoids boxing. One code path supporting both sync and async implementations.', markup='', info='', meta={}, block=False, hidden=False)], content='Note that the generic constraint on the TReader parameter here allows the implementation to invoke the interface methods, and passing the structs as a generic avoids boxing. One code path supporting both sync and async implementations.', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6763, 6764], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6763, 6764], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='This latter generic approach is how SslStream has historically handled the unification of its sync and async implementations. It gets better in .NET 7 with C# 11 now that we have static abstract methods in interfaces. We can instead declare our interface as (note the static abstract addition):', markup='', info='', meta={}, block=False, hidden=False)], content='This latter generic approach is how SslStream has historically handled the unification of its sync and async implementations. It gets better in .NET 7 with C# 11 now that we have static abstract methods in interfaces. We can instead declare our interface as (note the static abstract addition):', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6765, 6771], level=0, children=None, content='interface IReader\n{\n static abstract ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6772, 6773], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6772, 6773], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='our types as (note the static addition):', markup='', info='', meta={}, block=False, hidden=False)], content='our types as (note the static addition):', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6774, 6782], level=0, children=None, content='struct SyncReader : IReader\n{\n public static ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer) =>\n new ValueTask<int>(s.Read(buffer.Span));\n}\nstruct AsyncReader : IReader\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6783, 6789], level=0, children=None, content='{\n public static ValueTask<int> ReadAsync(Stream s, Memory<byte> buffer) =>\n s.ReadAsync(buffer);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6790, 6791], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6790, 6791], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='and our consuming methods as (note the removal of the parameter and the switch to calling static methods on the type parameter):', markup='', info='', meta={}, block=False, hidden=False)], content='and our consuming methods as (note the removal of the parameter and the switch to calling static methods on the type parameter):', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[6792, 6810], level=0, children=None, content='public static void Work(Stream s) =>\n A<SyncReader>(stream).GetAwaiter().GetResult(); // to propagate any exceptions\npublic static Task WorkAsync(Stream S) =>\n A<AsyncReader>(s);\ninternal static async Task A<TReader>(Stream s) where TReader : IReader\n{\n ...\n await B<TReader>(s);\n ...\n}\nprivate static async Task B<TReader>(Stream s) where TReader : IReader\n{\n ...\n int bytesRead = await TReader.ReadAsync(s, buffer);\n ...\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[6811, 6812], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[6811, 6812], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="Not only is this cleaner, but from a performance perspective we no longer need to pass around the dummy generic parameter, which is general goodness, but for an async method it's particularly beneficial because the state machine type ends up storing all parameters as fields, which means every parameter can increase the amount of allocation incurred by an async method if the method ends up completing asynchronously. ", markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/65239'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#65239', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" flipped SslStream (and NegotiateStream) to follow this approach. It's also used in multiple other places now throughout dotnet/runtime. ", markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/69278'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#69278', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False,