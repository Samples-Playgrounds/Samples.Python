des in the tree is handled.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[5933, 5945], level=0, children=None, content='[Params(100)]\npublic int Count { get; set; }\nprivate static SortedSet<string> _set;\n[GlobalSetup]\npublic void GlobalSetup()\n{\n _set = new SortedSet<string>(StringComparer.OrdinalIgnoreCase);\n for (int i = 0; i < Count; i++)\n {\n _set.Add(Guid.NewGuid().ToString());\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[5946, 5955], level=0, children=None, content=' }\n}\n[Benchmark]\npublic SortedSet<string> SortedSetCopy()\n{\n return new SortedSet<string>(_set, StringComparer.OrdinalIgnoreCase);\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='table_open', tag='table', nesting=1, attrs={}, map=[5956, 5960], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='thead_open', tag='thead', nesting=1, attrs={}, map=[5956, 5957], level=1, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='tr_open', tag='tr', nesting=1, attrs={}, map=[5956, 5957], level=2, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[5956, 5957], level=4, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Method', markup='', info='', meta={}, block=False, hidden=False)], content='Method', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_close', tag='t