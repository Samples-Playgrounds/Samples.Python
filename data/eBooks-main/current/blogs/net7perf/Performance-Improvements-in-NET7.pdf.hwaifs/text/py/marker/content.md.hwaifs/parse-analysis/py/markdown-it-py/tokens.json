attrs={}, map=[1855, 1869], level=0, children=None, content='G_M000_IG01: ;; offset=0000H\n 4883EC28 sub rsp, 40\nG_M000_IG02: ;; offset=0004H\n 83790800 cmp dword ptr [rcx+08H], 0\n 7608 jbe SHORT G_M000_IG04\n 8B4110 mov eax, dword ptr [rcx+10H]\nG_M000_IG03: ;; offset=000DH\n 4883C428 add rsp, 40\n C3 ret\nG_M000_IG04: ;; offset=0012H\n E8E9A0C25F call CORINFO_HELP_RNGCHKFAIL\n CC int3\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1870, 1871], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1870, 1871], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='The array is passed into this method in the rcx register, pointing to the method table pointer in the object, and the length of an array is stored in the object just after that method table pointer (which is 8 bytes in a 64-bit process). Thus the cmp dword ptr [rcx+08H], 0 instruction is reading the length', markup='', info='', meta={}, block=False, hidden=False)], content='The array is passed into this method in the rcx register, pointing to the method table pointer in the object, and the length of an array is stored in the object just after that method table pointer (which is 8 bytes in a 64-bit process). Thus the cmp dword ptr [rcx+08H], 0 instruction is reading the length', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1872, 1873], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1872, 1873], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="of the array and comparing the length to 0; that makes sense, since the length can't be negative, and we're trying to access the 0th element, so as long as the length isn't 0, the array has enough elements for us to access its 0th element. In the event that the length was 0, the code jumps to the end of the function, which contains call CORINFO_HELP_RNGCHKFAIL; that's a JIT helper function that throws an IndexOutOfRangeException. If the length was sufficient, however, it then reads the int stored at the beginning of the array's data, which on 64-bit is 16 bytes (0x10) past the pointer (mov eax, dword ptr [rcx+10H]).", markup='', info='', meta={}, block=False, hidden=False)], content="of the array and comparing the length to 0; that makes sense, since the length can't be negative, and we're trying to access the 0th element, so as long as the length isn't 0, the array has enough elements for us to access its 0th element. In the event that the length was 0, the code jumps to the end of the function, which contains call CORINFO\\_HELP\\_RNGCHKFAIL; that's a JIT helper function that throws an IndexOutOfRangeException. If the length was sufficient, however, it then reads the int stored at the beginning of the array's data, which on 64-bit is 16 bytes (0x10) past the pointer (mov eax, dword ptr [rcx+10H]).", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1874, 1875], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1874, 1875], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='While these bounds checks in and of themselves aren\'t super expensive, do a lot of them and their costs add up. So while the JIT needs to ensure that "safe" accesses don\'t go out of bounds, it also tries to prove that certain accesses won\'t, in which case it needn\'t emit the bounds check that it knows will be superfluous. In every release of .NET, more and more cases have been added to find places these bounds checks can be eliminated, and .NET 7 is no exception.', markup='', info='', meta={}, block=False, hidden=False)], content='While these bounds checks in and of themselves aren\'t super expensive, do a lot of them and their costs add up. So while the JIT needs to ensure that "safe" accesses don\'t go out of bounds, it also tries to prove that certain accesses won\'t, in which case it needn\'t emit the bounds check that it knows will be superfluous. In every release of .NET, more and more cases have been added to find places these bounds checks can be eliminated, and .NET 7 is no exception.', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1876, 1877], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1876, 1877], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='For example, ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/61662'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#61662', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/anthonycanino'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@anthonycanino', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' enabled the JIT to understand various forms of binary operations as part of range checks. Consider this method:', markup='', info='', meta={}, block=False, hidden=False)], content='For example, [dotnet/runtime#61662](https://github.com/dotnet/runtime/pull/61662) from [@anthonycanino](https://github.com/anthonycanino) enabled the JIT to understand various forms of binary operations as part of range checks. Consider this method:', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1878, 1894], level=0, children=None, content='[MethodImpl(MethodImplOptions.NoInlining)]\nprivate static ushort[]? Convert(ReadOnlySpan<byte> bytes)\n{\n if (bytes.Length != 16)\n {\n return null;\n }\n var result = new ushort[8];\n for (int i = 0; i < result.Length; i++)\n {\n result[i] = (ushort)(bytes[i * 2] * 256 + bytes[i * 2 + 1]);\n }\n return result;\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1895, 1896], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1895, 1896], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="It's validating that the input span is 16 bytes long and then creating a new ushort[8] where each ushort in the array combines two of the input bytes. To do that, it's looping over the output array, and indexing into the bytes array using i * 2 and i * 2 + 1 as the indices. On .NET 6, each of those indexing operations would result in a bounds check, with assembly like:", markup='', info='', meta={}, block=False, hidden=False)], content="It's validating that the input span is 16 bytes long and then creating a new ushort[8] where each ushort in the array combines two of the input bytes. To do that, it's looping over the output array, and indexing into the bytes array using i \\* 2 and i \\* 2 + 1 as the indices. On .NET 6, each of those indexing operations would result in a bounds check, with assembly like:", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1897, 1902], level=0, children=None, content='cmp r8d,10 \njae short G_M000_IG04 \nmovsxd r8,r8d\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1903, 1904], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1903, 1904], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="where that G_M000_IG04 is the call CORINFO_HELP_RNGCHKFAIL we're now familiar with. But on .NET 7, we get this assembly for the method:", markup='', info='', meta={}, block=False, hidden=False)], content="where that G\\_M000\\_IG04 is the call CORINFO\\_HELP\\_RNGCHKFAIL we're now familiar with. But on .NET 7, we get this assembly for the method:", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1905, 1913], level=0, children=None, content='G_M000_IG01: ;; offset=0000H\n 56 push rsi\n 4883EC20 sub rsp, 32\nG_M000_IG02: ;; offset=0005H\n 488B31 mov rsi, bword ptr [rcx]\n 8B4908 mov ecx, dword ptr [rcx+08H]\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[1914, 1950], level=0, children=None, content=' 83F910 cmp ecx, 16\n 754C jne SHORT G_M000_IG05\n 48B9302F542FFC7F0000 mov rcx, 0x7FFC2F542F30\n BA08000000 mov edx, 8\n E80C1EB05F call CORINFO_HELP_NEWARR_1_VC\n 33D2 xor edx, edx\n align [0 bytes for IG03]\nG_M000_IG03: ;; offset=0026H\n 8D0C12 lea ecx, [rdx+rdx]\n 448BC1 mov r8d, ecx\n FFC1 inc ecx\n 458BC0 mov r8d, r8d\n 460FB60406 movzx r8, byte ptr [rsi+r8]\n 41C1E008 shl r8d, 8\n 8BC9 mov ecx, ecx\n 0FB60C0E movzx rcx, byte ptr [rsi+rcx]\n 4103C8 add ecx, r8d\n 0FB7C9 movzx rcx, cx\n 448BC2 mov r8d, edx\n 6642894C4010 mov word ptr [rax+2*r8+10H], cx\n FFC2 inc edx\n 83FA08 cmp edx, 8\n 7CD0 jl SHORT G_M000_IG03\nG_M000_IG04: ;; offset=0056H\n 4883C420 add rsp, 32\n 5E pop rsi\n C3 ret\nG_M000_IG05: ;; offset=005CH\n 33C0 xor rax, rax\nG_M000_IG06: ;; offset=005EH\n 4883C420 add rsp, 32\n 5E pop rsi\n C3 ret\n; Total bytes of code 100\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1951, 1952], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[1951, 1952], level=1, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content="No bounds checks, which is most easily seen by the lack of the telltale call CORINFO_HELP_RNGCHKFAIL at the end of the method. With this PR, the JIT is able to understand the impact of certain multiplication and shift operations and their relationships to the bounds of the data structure. Since it can see that the result array's length is 8 and the loop is iterating from 0 to that exclusive upper bound, it knows that i will always be in the range [0, 7], which means that i * 2 will always be in the range [0, 14] and i * 2 + 1 will always be in the range [0, 15]. As such, it's able to prove that the bounds checks aren't needed.", markup='', info='', meta={}, block=False, hidden=False)], content="No bounds checks, which is most easily seen by the lack of the telltale call CORINFO\\_HELP\\_RNGCHKFAIL at the end of the method. With this PR, the JIT is able to understand the impact of certain multiplication and shift operations and their relationships to the bounds of the data structure. Since it can see that the result array's length is 8 and the loop is iterating from 0 to that exclusive upper bound, it knows that i will always be in the range [0, 7], which means that i \\* 2 will always be in the range [0, 14] and i \\* 2 + 1 will always be in the range [0, 15]. As such, it's able to prove that the bounds checks aren't needed.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_open', tag='p', nesting=1, attrs={}, map=[1953, 1954], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden