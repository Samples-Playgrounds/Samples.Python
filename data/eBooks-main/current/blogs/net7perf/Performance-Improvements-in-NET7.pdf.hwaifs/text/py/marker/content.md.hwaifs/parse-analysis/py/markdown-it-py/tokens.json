ef': 'https://github.com/dotnet/runtime/pull/70095'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#70095', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/teo-tsirpanis'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@teotsirpanis', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=". System.HashCode's goal is to provide a fast, easy-to-use implementation for producing high-quality hash codes. In its current incarnation, it incorporates a random process-wide seed and is an implementation of the xxHash32 non-cryptographic hash algorithm. In a previous release, HashCode saw the addition of an AddBytes methods, which accepts a ReadOnlySpan", markup='', info='', meta={}, block=False, hidden=False), Token(type='html_inline', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='<byte>', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" and is useful for incorporating sequences of data that should be part of a type's hash code, e.g. BigInteger.GetHashCode includes all the data that makes up the BigInteger. The xxHash32 algorithm works by accumulating 4 32-bit unsigned integers and then combining them together into the hash code; thus if you call HashCode.Add(int), the first three times you call it you're just storing the values separately into the instance, and then the fourth time you call it all of those values are combined into the hash code (and there's a separate process that incorporates any remaining values if the number of 32-bit values added wasn't an exact multiple of 4). Thus, previously AddBytes was simply implemented to repeatedly read the next 4 bytes from the input span and call Add(int) with those bytes as an integer. But those Add calls have overhead. Instead, this PR skips the Add calls and directly handles the accumulation and combining of the 16 bytes. Interestingly, it still has to deal with the possibility that previous calls to Add may have left some state queued, which means (with the current implementation at least), if there are multiple pieces of state to include in the hash code, say a ReadOnlySpan", markup='', info='', meta={}, block=False, hidden=False), Token(type='html_inline', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='<byte>', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" and an additional int, it's more efficient to add the span first and then the int rather than the other way around. So for example when ", markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/dotnet/runtime/pull/71274'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='dotnet/runtime#71274', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' from ', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_open', tag='a', nesting=1, attrs={'href': 'https://github.com/huoyaoyuan'}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='@huoyaoyuan', markup='', info='', meta={}, block=False, hidden=False), Token(type='link_close', tag='a', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=" changed BigInteger.GetHashCode to use HashCode.AddBytes, it coded the method to first call AddBytes with the BigInteger's _bits and ", markup='', info='', meta={}, block=False, hidden=False), Token(type='em_open', tag='em', nesting=1, attrs={}, map=None, level=0, children=None, content='', markup='*', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=1, children=None, content='then', markup='', info='', meta={}, block=False, hidden=False), Token(type='em_close', tag='em', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='*', info='', meta={}, block=False, hidden=False), Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content=' call Add with the _sign.', markup='', info='', meta={}, block=False, hidden=False)], content="Another impactful span-related change comes in [dotnet/runtime#70095](https://github.com/dotnet/runtime/pull/70095) from [@teotsirpanis](https://github.com/teo-tsirpanis). System.HashCode's goal is to provide a fast, easy-to-use implementation for producing high-quality hash codes. In its current incarnation, it incorporates a random process-wide seed and is an implementation of the xxHash32 non-cryptographic hash algorithm. In a previous release, HashCode saw the addition of an AddBytes methods, which accepts a ReadOnlySpan<byte> and is useful for incorporating sequences of data that should be part of a type's hash code, e.g. BigInteger.GetHashCode includes all the data that makes up the BigInteger. The xxHash32 algorithm works by accumulating 4 32-bit unsigned integers and then combining them together into the hash code; thus if you call HashCode.Add(int), the first three times you call it you're just storing the values separately into the instance, and then the fourth time you call it all of those values are combined into the hash code (and there's a separate process that incorporates any remaining values if the number of 32-bit values added wasn't an exact multiple of 4). Thus, previously AddBytes was simply implemented to repeatedly read the next 4 bytes from the input span and call Add(int) with those bytes as an integer. But those Add calls have overhead. Instead, this PR skips the Add calls and directly handles the accumulation and combining of the 16 bytes. Interestingly, it still has to deal with the possibility that previous calls to Add may have left some state queued, which means (with the current implementation at least), if there are multiple pieces of state to include in the hash code, say a ReadOnlySpan<byte> and an additional int, it's more efficient to add the span first and then the int rather than the other way around. So for example when [dotnet/runtime#71274](https://github.com/dotnet/runtime/pull/71274) from [@huoyaoyuan](https://github.com/huoyaoyuan) changed BigInteger.GetHashCode to use HashCode.AddBytes, it coded the method to first call AddBytes with the BigInteger's \\_bits and *then* call Add with the \\_sign.", markup='', info='', meta={}, block=True, hidden=False), Token(type='paragraph_close', tag='p', nesting=-1, attrs={}, map=None, level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='fence', tag='code', nesting=0, attrs={}, map=[5194, 5204], level=0, children=None, content='private byte[] _data = Enumerable.Range(0, 256).Select(i => (byte)i).ToArray();\n[Benchmark]\npublic int AddBytes()\n{\n HashCode hc = default;\n hc.AddBytes(_data);\n return hc.ToHashCode();\n}\n', markup='```', info='', meta={}, block=True, hidden=False), Token(type='table_open', tag='table', nesting=1, attrs={}, map=[5205, 5209], level=0, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='thead_open', tag='thead', nesting=1, attrs={}, map=[5205, 5206], level=1, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='tr_open', tag='tr', nesting=1, attrs={}, map=[5205, 5206], level=2, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[5205, 5206], level=4, children=[Token(type='text', tag='', nesting=0, attrs={}, map=None, level=0, children=None, content='Method', markup='', info='', meta={}, block=False, hidden=False)], content='Method', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_close', tag='th', nesting=-1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='th_open', tag='th', nesting=1, attrs={}, map=None, level=3, children=None, content='', markup='', info='', meta={}, block=True, hidden=False), Token(type='inline', tag='', nesting=0, attrs={}, map=[5205, 5206], level=4, children=[Token(type='text', tag='', nesting=0, attrs={}, map